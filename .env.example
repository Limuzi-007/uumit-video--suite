# UUMit Video Suite Configuration
HOST=0.0.0.0
PORT=8000

# API Keys (for authentication)
# Format: key1,key2,...
API_KEYS=sk-test-1234

# UUMit Configuration
UUMIT_SKILL_ID=your-skill-id
UUMIT_API_KEY=your-uumit-api-key

# Whisper model: tiny, base, small, medium, large
WHISPER_MODEL=base

# Upload & Output directories
UPLOAD_DIR=./uploads
OUTPUT_DIR=./outputs

# Max file size (bytes) - 500MB
MAX_FILE_SIZE=524288000

# Rate limiting
RATE_LIMIT_PER_MIN=60

# Logging
LOG_LEVEL=INFO
